#version 460
#extension GL_EXT_ray_tracing : enable

#define PT_CONFIG_SBT_RAYGEN
#include "Common.glsl"

// The SBT payload, trace wrappers and the whole render loop (ptRenderPixel) are shared
// via PathTracerContext.glsl / PathTracerCore.glsl, included through Common.glsl.

void main()
{
	PathTracerContext ctx;
	ptRenderPixel(ctx, ivec2(gl_LaunchIDEXT.xy));
}
